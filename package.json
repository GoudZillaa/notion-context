{
  "name": "@goudzillaa/notion-context",
  "version": "0.1.1",
  "description": "A CLI tool to fetch Notion data and generate local context files for AI assistants",
  "main": "dist/cli.js",
  "bin": {
    "notion-context": "dist/cli.js"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup src/cli.ts --format esm --clean --minify",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "notion",
    "cli",
    "context",
    "ai",
    "developer-tools"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@notionhq/client": "^5.9.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "inquirer": "^9.2.15"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.11.5",
    "tsup": "^8.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}